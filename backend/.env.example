# Required in production
SECRET_KEY=change-me-run:  python -c "import secrets; print(secrets.token_hex(32))"
CORS_ORIGINS=https://your-web-domain.com
ADMIN_EMAIL=admin@your-domain.com

# Stripe (leave blank to run in mock-payment dev mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
FRONTEND_URL=https://your-web-domain.com
# STRIPE_ALLOW_LIVE=true   (only after deploying — refuses sk_live_ keys otherwise)

# Optional
# DATABASE_URL=postgresql://user:pass@host:5432/getbuddy   (defaults to sqlite:///./getbuddy.db)
# OTP_CODE=some-secret-code    (until a real SMS provider is integrated; unset = dev mock 123456)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
